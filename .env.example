# ── Server ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=https://huntz.lovable.app

# ── Database (PostgreSQL) ────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=huntz
DB_USER=huntz_user
DB_PASSWORD=your_db_password

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=d4a7a8d0390dcd7aacf05d4013abec0842f36386ac8c3ece5d36b08d8621eab9
JWT_EXPIRES_IN=7d

# ── File Storage (AWS S3 or compatible) ──────────────────
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=eu-west-2
AWS_BUCKET_NAME=huntz-uploads

# ── Prembly (Identity Verification) ─────────────────────
PREMBLY_API_KEY=your_prembly_api_key
PREMBLY_APP_ID=your_prembly_app_id
# Set to true during development to skip real Prembly API calls.
# REMOVE or set to false before going live.
PREMBLY_DEV_BYPASS=true

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key

# ── Resend (Email) ───────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=Huntz <noreply@huntz.com>

# ── App URL (used in email links) ────────────────────────
API_URL=https://api.huntz.com

# ── API Secret Key ────────────────────────────────────────
# All requests from the frontend must include this in the x-api-key header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET_KEY=db5daef28d19da53b07fd8b867a6e0c40dbe30ba9f42bbc28ab22254d2a9012f
